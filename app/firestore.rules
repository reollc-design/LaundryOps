rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid);
    }

    function organizationPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId);
    }

    function isOrganizationOwner(orgId) {
      return signedIn()
        && exists(organizationPath(orgId))
        && get(organizationPath(orgId)).data.ownerUserId == request.auth.uid;
    }

    function isMember(orgId) {
      return signedIn()
        && (
          (
            exists(memberPath(orgId))
            && get(memberPath(orgId)).data.status == 'active'
          )
          || isOrganizationOwner(orgId)
        );
    }

    function hasRole(orgId, roles) {
      return signedIn()
        && (
          (
            exists(memberPath(orgId))
            && get(memberPath(orgId)).data.status == 'active'
            && get(memberPath(orgId)).data.role in roles
          )
          || (isOrganizationOwner(orgId) && 'owner' in roles)
        );
    }

    function isOwnerOrAdmin(orgId) {
      return hasRole(orgId, ['owner', 'admin']);
    }

    function isOperationsLead(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'manager']);
    }

    function isTechnician(orgId) {
      return hasRole(orgId, ['technician']);
    }

    function unchanged(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny([
          'role',
          'organizationRole',
          'billingStatus',
          'subscriptionStatus',
          'supportAccess'
        ]);
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isMember(orgId);
      allow create: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.subscriptionStatus == 'trialing'
        && request.resource.data.keys().hasOnly([
          'name',
          'operatorName',
          'businessAddress',
          'ownerEmail',
          'ownerUserId',
          'createdBy',
          'createdAt',
          'subscriptionStatus',
          'trialStartedAt',
          'onboardingStatus'
        ]);
      allow delete: if false;
      allow update: if isOwnerOrAdmin(orgId)
        && unchanged([
          'billingStatus',
          'subscriptionStatus',
          'providerCustomerId',
          'providerSubscriptionId',
          'ownerUserId',
          'trialStartedAt',
          'trialEndsAt',
          'createdAt',
          'createdBy'
        ]);

      match /memberships/{userId} {
        allow read: if isOwnerOrAdmin(orgId) || (signedIn() && request.auth.uid == userId);
        allow create: if signedIn()
          && userId == request.auth.uid
          && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUserId == request.auth.uid
          && request.resource.data.role == 'owner'
          && request.resource.data.status == 'active'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'role',
            'status',
            'createdAt',
            'createdBy'
          ]);
        allow update, delete: if false;
      }

      match /machines/{machineId} {
        allow read: if isMember(orgId);
        allow create: if isOperationsLead(orgId);
        allow update: if isOperationsLead(orgId)
          || (
            isTechnician(orgId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'statusLabel',
              'updatedAt',
              'updatedBy',
              'lastServicedAt'
            ])
          );
        allow delete: if isOwnerOrAdmin(orgId);
      }

      match /workOrders/{workOrderId} {
        allow read: if isMember(orgId);
        allow create: if isOperationsLead(orgId);
        allow update: if isOperationsLead(orgId)
          || (
            isTechnician(orgId)
            && resource.data.assignedUserId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'statusLabel',
              'updatedAt',
              'updatedBy',
              'completedAt'
            ])
          );
        allow delete: if isOwnerOrAdmin(orgId);
      }

      match /maintenanceEvents/{eventId} {
        allow read: if isMember(orgId);
        allow create: if hasRole(orgId, ['owner', 'admin', 'manager', 'technician']);
        allow update, delete: if isOwnerOrAdmin(orgId);
      }

      match /manuals/{manualId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if hasRole(orgId, ['owner', 'admin', 'manager']);

        match /chunks/{chunkId} {
          allow read: if isMember(orgId);
          allow create, update, delete: if false;
        }
      }

      match /files/{fileId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if false;
      }

      match /aiDiagnoses/{diagnosisId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }

      match /auditLogs/{auditLogId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }

      match /backups/{backupId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
