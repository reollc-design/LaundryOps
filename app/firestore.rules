rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid);
    }

    function organizationPath(orgId) {
      return /databases/$(database)/documents/organizations/$(orgId);
    }

    function isOrganizationOwner(orgId) {
      return signedIn()
        && exists(organizationPath(orgId))
        && get(organizationPath(orgId)).data.ownerUserId == request.auth.uid;
    }

    function isMember(orgId) {
      return signedIn()
        && (
          (
            exists(memberPath(orgId))
            && get(memberPath(orgId)).data.status == 'active'
          )
          || isOrganizationOwner(orgId)
        );
    }

    function hasRole(orgId, roles) {
      return signedIn()
        && (
          (
            exists(memberPath(orgId))
            && get(memberPath(orgId)).data.status == 'active'
            && get(memberPath(orgId)).data.role in roles
          )
          || (isOrganizationOwner(orgId) && 'owner' in roles)
        );
    }

    function isOwnerOrAdmin(orgId) {
      return hasRole(orgId, ['owner', 'admin']);
    }

    function isOperationsLead(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'manager']);
    }

    function isTechnician(orgId) {
      return hasRole(orgId, ['technician']);
    }

    function hasValidPhotoAttachmentCount() {
      return !('photoAttachments' in request.resource.data)
        || (
          request.resource.data.photoAttachments is list
          && request.resource.data.photoAttachments.size() <= 3
        );
    }

    function isOrganizationActive(orgId) {
      return signedIn()
        && exists(organizationPath(orgId))
        && (
          (
            'accessEntitlement' in get(organizationPath(orgId)).data
            && get(organizationPath(orgId)).data.accessEntitlement == 'developer'
          )
          || get(organizationPath(orgId)).data.subscriptionStatus == 'active'
          || (
            get(organizationPath(orgId)).data.subscriptionStatus == 'trialing'
            && get(organizationPath(orgId)).data.trialEndsAt is timestamp
            && request.time < get(organizationPath(orgId)).data.trialEndsAt
          )
        );
    }

    function isOnboardingOwner(orgId) {
      return signedIn()
        && getAfter(organizationPath(orgId)).data.ownerUserId == request.auth.uid
        && getAfter(organizationPath(orgId)).data.createdBy == request.auth.uid
        && getAfter(memberPath(orgId)).data.role == 'owner'
        && getAfter(memberPath(orgId)).data.status == 'active'
        && getAfter(memberPath(orgId)).data.createdBy == request.auth.uid;
    }

    function isOrganizationActiveForWrite(orgId) {
      return isOrganizationActive(orgId)
        || (
          isOnboardingOwner(orgId)
          && getAfter(organizationPath(orgId)).data.subscriptionStatus == 'trialing'
          && getAfter(organizationPath(orgId)).data.trialEndsAt is timestamp
          && request.time < getAfter(organizationPath(orgId)).data.trialEndsAt
        );
    }

    function hasValidTrialWindow() {
      return request.resource.data.trialStartedAt is timestamp
        && request.resource.data.trialEndsAt is timestamp
        && request.resource.data.trialStartedAt <= request.time
        && request.resource.data.trialEndsAt == request.resource.data.trialStartedAt + duration.value(14, 'd');
    }

    function unchanged(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny([
          'role',
          'organizationRole',
          'billingStatus',
          'subscriptionStatus',
          'supportAccess'
        ]);
      allow delete: if false;
    }

    match /organizations/{orgId} {
      allow read: if isMember(orgId);
      allow create: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.subscriptionStatus == 'trialing'
        && hasValidTrialWindow()
        && request.resource.data.keys().hasOnly([
          'name',
          'operatorName',
          'businessAddress',
          'ownerEmail',
          'ownerUserId',
          'createdBy',
          'createdAt',
          'subscriptionStatus',
          'trialStartedAt',
          'trialEndsAt',
          'onboardingStatus'
        ]);
      allow delete: if false;
      allow update: if isOwnerOrAdmin(orgId)
        && unchanged([
          'billingStatus',
          'billingProvider',
          'subscriptionStatus',
          'providerCustomerId',
          'providerSubscriptionId',
          'lastStripeBillingEventType',
          'lastStripeBillingEventId',
          'lastStripeBillingEventCreated',
          'accessEntitlement',
          'accessEntitlementGrantedAt',
          'accessEntitlementGrantedBy',
          'ownerUserId',
          'trialStartedAt',
          'trialEndsAt',
          'createdAt',
          'createdBy'
        ]);

      match /memberships/{userId} {
        allow read: if isOwnerOrAdmin(orgId) || (signedIn() && request.auth.uid == userId);
        allow create: if signedIn()
          && userId == request.auth.uid
          && getAfter(organizationPath(orgId)).data.ownerUserId == request.auth.uid
          && request.resource.data.role == 'owner'
          && request.resource.data.status == 'active'
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'role',
            'status',
            'createdAt',
            'createdBy'
          ]);
        allow update, delete: if false;
      }

      match /locations/{locationId} {
        allow read: if isMember(orgId);
        allow create: if isOrganizationActiveForWrite(orgId)
          && (isOperationsLead(orgId) || isOnboardingOwner(orgId))
          && request.resource.data.name is string
          && request.resource.data.address is string
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'name',
            'address',
            'status',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ]);
        allow update: if isOrganizationActive(orgId)
          && isOperationsLead(orgId)
          && unchanged(['createdAt', 'createdBy']);
        allow delete: if isOrganizationActive(orgId) && isOwnerOrAdmin(orgId);
      }

      match /machines/{machineId} {
        allow read: if isMember(orgId);
        allow create: if isOrganizationActiveForWrite(orgId)
          && (isOperationsLead(orgId) || isOnboardingOwner(orgId));
        allow update: if isOrganizationActive(orgId)
          && (
            isOperationsLead(orgId)
            || (
              isTechnician(orgId)
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'statusLabel',
                'updatedAt',
                'updatedBy',
                'lastServicedAt'
              ])
            )
          );
        allow delete: if isOrganizationActive(orgId) && isOwnerOrAdmin(orgId);
      }

      match /workOrders/{workOrderId} {
        allow read: if isMember(orgId);
        allow create: if isOrganizationActive(orgId)
          && isOperationsLead(orgId)
          && hasValidPhotoAttachmentCount();
        allow update: if isOrganizationActive(orgId)
          && (
            (isOperationsLead(orgId) && hasValidPhotoAttachmentCount())
            || (
              isTechnician(orgId)
              && resource.data.assignedUserId == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'statusLabel',
                'updatedAt',
                'updatedBy',
                'completedAt'
              ])
            )
          );
        allow delete: if isOrganizationActive(orgId) && isOwnerOrAdmin(orgId);
      }

      match /maintenanceEvents/{eventId} {
        allow read: if isMember(orgId);
        allow create: if isOrganizationActive(orgId) && hasRole(orgId, ['owner', 'admin', 'manager', 'technician']);
        allow update, delete: if isOrganizationActive(orgId) && isOwnerOrAdmin(orgId);
      }

      match /manuals/{manualId} {
        allow read: if isMember(orgId);
        allow create, update: if isOrganizationActive(orgId) && hasRole(orgId, ['owner', 'admin', 'manager']);
        allow delete: if false;

        match /{chunkCollection}/{chunkId} {
          allow read: if isMember(orgId)
            && chunkCollection.matches('chunks(_v[a-z0-9]+_[a-z0-9]+)?');
          allow create, update, delete: if false;
        }
      }

      match /files/{fileId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if false;
      }

      match /aiDiagnoses/{diagnosisId} {
        allow read: if isMember(orgId);
        allow create, update, delete: if false;
      }

      match /subscriptions/{subscriptionId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }

      match /auditLogs/{auditLogId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }

      match /backups/{backupId} {
        allow read: if isOwnerOrAdmin(orgId);
        allow create, update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
