rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(orgId) {
      return /databases/(default)/documents/organizations/$(orgId)/memberships/$(request.auth.uid);
    }

    function isMember(orgId) {
      return signedIn()
        && firestore.exists(memberPath(orgId))
        && firestore.get(memberPath(orgId)).data.status == 'active';
    }

    function hasRole(orgId, roles) {
      return isMember(orgId) && firestore.get(memberPath(orgId)).data.role in roles;
    }

    function isOperationalRole(orgId) {
      return hasRole(orgId, ['owner', 'admin', 'manager', 'technician']);
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isReasonableUpload() {
      return request.resource.size < 25 * 1024 * 1024;
    }

    match /orgs/{orgId}/manuals/{manualId}/{fileName=**} {
      allow read: if isMember(orgId);
      allow write: if hasRole(orgId, ['owner', 'admin', 'manager'])
        && isReasonableUpload()
        && isPdf();
    }

    match /orgs/{orgId}/machines/{machineId}/photos/{fileName=**} {
      allow read: if isMember(orgId);
      allow write: if isOperationalRole(orgId)
        && isReasonableUpload()
        && isImage();
    }

    match /orgs/{orgId}/workOrders/{workOrderId}/attachments/{fileName=**} {
      allow read: if isMember(orgId);
      allow write: if isOperationalRole(orgId)
        && isReasonableUpload()
        && (isImage() || isPdf());
    }

    match /orgs/{orgId}/exports/{exportId}/{fileName=**} {
      allow read: if hasRole(orgId, ['owner', 'admin']);
      allow write: if false;
    }

    match /orgs/{orgId}/backups/{backupId}/{fileName=**} {
      allow read: if hasRole(orgId, ['owner']);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
